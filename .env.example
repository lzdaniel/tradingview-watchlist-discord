# Required: Discord channel webhook URL.
DISCORD_WEBHOOK_URL=<your-discord-webhook-url>

# Huang watchlist.
WATCHLIST_NAME=黄哥的观察
WATCHLIST_URL=https://www.tradingview.com/watchlists/326877343/

# State snapshot location. Relative paths are resolved from the project root.
STATE_FILE=state/watchlist_326877343.json

# US regular session defaults. The scheduler treats weekdays as trading days;
# holidays are not excluded unless you pause the daemon yourself.
MARKET_TIMEZONE=America/New_York
MARKET_OPEN=09:30
MARKET_CLOSE=16:00
CHECK_INTERVAL_MARKET_SECONDS=900
CHECK_INTERVAL_OFFHOURS_SECONDS=1800

# Browser options.
HEADLESS=true
# Optional: use a Playwright storage_state JSON file if TradingView requires login/cookies.
# TV_STORAGE_STATE=state/tradingview_storage_state.json

# Safety/testing.
DRY_RUN=false
SEND_INITIAL_BASELINE=false

# GitHub Actions should set this to false so no-change scans do not create state commits.
PERSIST_LAST_SEEN=true
